# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
*.tgz

# Chart version files
Chart.lock
charts/*/Chart.lock

# Dependency directories
charts/
tmp/

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Git files
.git
.gitignore

# Documentation
docs/
*.md
!README.md

# Test files
tests/
*.test.js
*.spec.js

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*
!.env.example

# Build output
dist/
build/ 